generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearchPostgres"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm, vector]
}

// Global Roles for Super Admin capabilities
enum GlobalRole {
  SUPER_ADMIN
  USER
}

// Legacy Tenant Roles for fallback/core logic
enum TenantRole {
  OWNER
  ADMIN
  MEMBER
}

// ------------------------------------------------------------------
// SAAS MULTI-TENANCY MODELS
// ------------------------------------------------------------------

model Tenant {
  id              String   @id @default(uuid())
  name            String
  
  members         TenantMember[]
  subscription    TenantSubscription?
  alertPreference TenantAlertPreference?
  creditTransactions CreditTransaction[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  roles           Role[]   // Custom roles created for this tenant
  savedFilters    SavedFilter[]
}

model TenantAlertPreference {
  id              String   @id @default(uuid())
  
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  keywords        String[] @default([])
  preferredStates String[] @default([])
  tenderValueRange String?
  companyWebsite  String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TenantMember {
  id              String   @id @default(uuid())
  
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  userId          String   // Maps to Keycloak User ID or UserProfile
  
  isOwner         Boolean  @default(false) // Absolute owner of the workspace
  
  roleId          String?
  customRole      Role?    @relation(fields: [roleId], references: [id])
  
  // Legacy enum, keeping it temporarily for backward compatibility during migration
  role            TenantRole @default(MEMBER)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, userId]) // A user can only have one membership per tenant
}

model Role {
  id              String   @id @default(uuid())
  name            String
  description     String?
  
  isSystemRole    Boolean  @default(false)
  isDefaultAdmin  Boolean  @default(false)
  isDefaultUser   Boolean  @default(false)
  
  tenantId        String?
  tenant          Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  permissions     String[] @default([])
  
  members         TenantMember[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TenantSubscription {
  id              String   @id @default(uuid())
  
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  planType        String   // "TRIAL", "BASIC", "PROFESSIONAL", "ENTERPRISE"
  status          String   // "ACTIVE", "EXPIRED", "CANCELLED", "PENDING_PAYMENT"
  
  startDate       DateTime
  endDate         DateTime
  
  // Credits and Usage
  availableCredits       Int @default(0)
  tendersViewedThisMonth Int @default(0)
  unlockedStates         String[] @default([])
  unlockedKeywords       String[] @default([])
  
  paymentMethod   String?  // "RAZORPAY_SUB", "MANUAL", etc.
  paymentId       String?  // e.g. Razorpay payment ID / Subscription ID
  amount          Float?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CreditTransaction {
  id              String   @id @default(uuid())
  
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  userId          String?  // The user who performed the action
  amount          Int      // Negative for deduction, positive for addition
  description     String   // e.g. "Unlocked Tender TL-1234"
  tenderId        String?  // Reference to the tender if applicable
  
  createdAt       DateTime @default(now())
}

model PricingPlan {
  id                  String   @id @default(uuid())
  name                String   @unique // "TRIAL", "BASIC", "PROFESSIONAL", "ENTERPRISE"
  price               Float?
  allowedTenderFields String[] @default([]) // e.g. ["tenderValue", "emd", "aiSummary"]
  
  // Hard Limits & Credits
  monthlyCredits      Int      @default(0)
  maxKeywords         Int      @default(3)
  maxStates           Int      @default(1)
  maxTenderViews      Int      @default(50)
  freeRedownloads     Int      @default(3)
  
  // Alerts
  hasEmailAlerts      Boolean  @default(false)
  hasWhatsappAlerts   Boolean  @default(false)
  hasSmsAlerts        Boolean  @default(false)
  
  isDefault           Boolean  @default(false)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model SavedFilter {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?  // The user who created the filter
  name      String
  filters   Json     // Storing { states, cities, categories, authorities, keywords, minAmount, maxAmount, searchQuery }
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserProfile {
  id              String   @id @default(uuid())
  userId          String   @unique // Maps to Keycloak User ID
  
  email           String?  @unique
  phoneNumber     String?
  companyName     String?
  
  globalRole      GlobalRole @default(USER) // For Super Admin
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ------------------------------------------------------------------
// UNIFIED PAN-INDIA TENDER MODEL
// ------------------------------------------------------------------

model OrganisationMapping {
  id              String   @id @default(uuid())
  rawName         String   @unique
  normalizedName  String?
  isMapped        Boolean  @default(false)
  state           String
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}


model Tender {
  id              String   @id @default(uuid())
  localId         Int      @default(autoincrement())
  tenderCode      String?  @unique // e.g. "TL-OD-000001" — human-readable reference ID

  // Geographic Metadata
  state           String?
  tenderId        String?   @unique // NICGEP Tender ID — primary dedup key e.g. "2026_OSCSC_134676_1"
  regionStateId   String?
  regionState     RegionState? @relation(fields: [regionStateId], references: [id])
  district        String?
  regionDistrictId String?
  regionDistrict  RegionDistrict? @relation(fields: [regionDistrictId], references: [id])
  city            String?   // populated from "Location" field
  location        String?   // raw location string from the source
  level           String?   // e.g., "CENTRAL", "STATE", "DISTRICT"
  organisation    String?
  pincode         String?

  // ── Basic Tender Details ───────────────────────────────────────────
  title           String
  description     String?
  tenderRefNumber String?   // e.g. "1392/06.07.2026"
  tenderType      String?   // "Open Tender" / "Limited Tender"
  formOfContract  String?   // "Percentage" / "Item Rate"
  tenderCategory  String?   // "Works" / "Services" / "Goods"
  noOfCovers      Int?
  paymentMode     String?   // "Online" / "Not Applicable"
  withdrawalAllowed        Boolean?
  twoStageBidding          Boolean?
  generalTechEvalAllowed   Boolean?
  itemWiseTechEvalAllowed  Boolean?
  multiCurrencyBOQ         Boolean?
  multiCurrencyFee         Boolean?

  // ── Payment Instruments ────────────────────────────────────────────
  onlineBankers   String?   // comma-joined bank names e.g. "ICICI BANK, ICICI NEFT/RTGS"

  // ── Covers Information ─────────────────────────────────────────────
  coversInfo      String?   // JSON array: [{coverNo, coverType, description, documentType}]

  // ── Work Item Details ──────────────────────────────────────────────
  productCategory     String?
  subCategory         String?
  contractType        String?
  bidValidityDays     Int?
  periodOfWorkDays    Int?
  bidOpeningPlace     String?
  preBidMeetingAddress String?
  preBidMeetingDate    DateTime?
  preBidMeetingPlace   String?
  ndaPreQualification  String?
  allowNdaTender       Boolean?
  allowPreferentialBidder Boolean?

  // ── Critical Dates ─────────────────────────────────────────────────
  publishedDate          DateTime?
  docDownloadStartDate   DateTime?
  docDownloadEndDate     DateTime?
  clarificationStartDate DateTime?
  clarificationEndDate   DateTime?
  bidOpeningDate         DateTime?

  startDate       DateTime?  // Bid Submission Start Date
  endDate         DateTime?  // Bid Submission End Date

  // ── Document URLs ──────────────────────────────────────────────────
  noticePdfUrl    String?
  tenderPdfUrl    String?

  // ── Tender Fee Details ─────────────────────────────────────────────
  tenderValue     String?
  tenderAmount    Float?    // Raw numeric value for min/max filtering
  emd             String?
  applicationCost String?   // Tender Fee in ₹
  vatCharges      String?
  feePayableTo    String?
  feePayableAt    String?
  feeExemptionAllowed String?

  // ── EMD Fee Details ────────────────────────────────────────────────
  emdExemptionAllowed String?
  emdFeeType          String?
  emdPercentage       String?
  emdPayableTo        String?
  emdPayableAt        String?

  // ── Tender Inviting Authority ──────────────────────────────────────
  invitingAuthorityName        String?
  invitingAuthorityAddress     String?
  invitingAuthorityDesignation String?
  organisationChain            String?

  // ── AI Processing ─────────────────────────────────────────────────
  aiData          TenderAiData?
  boq             TenderBoq?
  documentText    TenderDocumentText?

  sourceUrl       String?  // Real NICGEP detail URL (session-specific, for reference only)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([state, district])
  @@index([endDate])
  @@index([bidOpeningDate])
  @@index([productCategory])
  @@index([tenderAmount])
  @@index([createdAt(sort: Desc)])
  @@index([state(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([district(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([city(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([organisation(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([tenderCategory(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([startDate(sort: Desc), createdAt(sort: Desc)])
}

model TenderAiData {
  id              String   @id @default(uuid())
  tenderId        String   @unique
  tender          Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  
  aiCategory      String?
  aiSummary       String?
  tags            String[] @default([])
  aiProcessed     Boolean  @default(false)
  documentsDownloaded Boolean @default(false)
  aiError         String?
  embedding       Unsupported("vector(384)")?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([aiProcessed])
  @@index([aiSummary(ops: raw("gin_trgm_ops"))], type: Gin)
}

model TenderBoq {
  id        String   @id @default(uuid())
  tenderId  String   @unique
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  
  boqData   Json     // Array of BOQ items extracted from Excel

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TenderDocumentText {
  id        String   @id @default(uuid())
  tenderId  String   @unique
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  
  rawText   String   // The full extracted raw text from PDF/Documents
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// ------------------------------------------------------------------
// TENANT-ISOLATED TENDER INTERACTIONS
// ------------------------------------------------------------------

model TenantTenderAction {
  id              String   @id @default(uuid())
  
  tenantId        String
  tenderId        String   // References global Tender
  
  isBookmarked    Boolean  @default(false)
  isApplied       Boolean  @default(false)
  notes           String?
  
  updatedByUserId String?  // Which user in the tenant made the action
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, tenderId])
  @@index([tenantId])
  @@index([tenderId])
}

model TenantTenderView {
  id        String   @id @default(uuid())
  tenantId  String
  tenderId  String
  viewedAt  DateTime @default(now())

  @@unique([tenantId, tenderId])
  @@index([tenantId])
}

model TenantUnlockedTender {
  id              String   @id @default(uuid())
  
  tenantId        String
  tenderId        String
  
  downloadCount   Int      @default(1)
  unlockedAt      DateTime @default(now())

  @@unique([tenantId, tenderId])
}

// ------------------------------------------------------------------
// SYSTEM & SCRAPING LOGS
// ------------------------------------------------------------------

model ScrapeLog {
  id            String   @id @default(uuid())
  
  targetId      String?  // Reference to ScraperTarget.id (optional for backward compatibility)
  targetRegion  String   // e.g., "Odisha", "Maharashtra"
  status        String
  tendersFound  Int
  totalTenders  Int      @default(0)
  newTendersAdded Int    @default(0)
  error         String?
  source        String   @default("AUTO")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
}

model ScraperTarget {
  id        String   @id @default(uuid())
  name      String
  type      String   // "STATE", "DISTRICT"
  state     String?  @default("Odisha") // Legacy field
  
  regionStateId    String?
  regionState      RegionState?    @relation(fields: [regionStateId], references: [id], onDelete: Cascade)
  regionDistrictId String?
  regionDistrict   RegionDistrict? @relation(fields: [regionDistrictId], references: [id], onDelete: Cascade)

  url       String
  scraperType String @default("AUTO") // "AUTO", "NICGEP", "AP_EPROCUREMENT"
  isActive  Boolean  @default(true)
  isVerified Boolean @default(false)
  cronSchedule String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RegionState {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String?  @unique // e.g., "AP", "OD", "MH", "UP"
  districts RegionDistrict[]
  targets   ScraperTarget[]
  tenders   Tender[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RegionDistrict {
  id        String   @id @default(uuid())
  name      String
  stateId   String
  state     RegionState @relation(fields: [stateId], references: [id], onDelete: Cascade)
  targets   ScraperTarget[]
  tenders   Tender[]
  
  @@unique([name, stateId])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PriorityKeyword {
  id        String   @id @default(uuid())
  word      String   @unique
  createdAt DateTime @default(now())
}

model KeywordExpansion {
  id          String   @id @default(uuid())
  baseWord    String   @unique
  expansions  String[] @default([])
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model EmailRecipient {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
}

model OtpVerification {
  id        String   @id @default(uuid())
  phone     String   @unique
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
