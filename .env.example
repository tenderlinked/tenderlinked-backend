# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/tender_scrapper

# Gemini AI Keys (up to 4 for rotation)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY2=
GEMINI_API_KEY3=
GEMINI_API_KEY4=

# Microsoft Azure Graph API (for email)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# Cron secret for authenticating cron job calls
CRON_SECRET=your_cron_secret_here

# Server port (default: 3001)
PORT=3001
